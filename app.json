{
  "expo": {
    "name": "WaiterApp",
    "slug": "WaiterApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3f7ff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.HSL.WaiterApp",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#f3f7ff"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.HSL.WaiterApp"
    },
    "web": {
      "favicon": "./assets/app-icon.png"
    },
    "plugins": [
      "./plugins/withAndroidCleartextTraffic",
      "expo-sqlite",
      "expo-font"
    ],
    "extra": {
      "NODE_ENV": "DEV",
      "API_ENV": "dev",
      "SERVER_BASE_URL_DEV": "http://146.190.9.120:3000/",
      "SERVER_BASE_URL_LIVE": "https://live-api.atgpos.de/",
      "LOCAL_BASE_URL": "",
      "eas": {
        "projectId": "109695e7-d1ce-41de-bb69-775182d1345d"
      }
    },
    "owner": "nagpalarpit"
  }
}
